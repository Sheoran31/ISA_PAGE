# =============================================
# STOCK ALERT SYSTEM - CONFIGURATION TEMPLATE
# Copy this to .env and fill in your values
# NEVER commit .env to git
# =============================================

# --- Data Provider ---
# Using Yahoo Finance (yfinance) - no authentication needed
# Supports symbols like: RELIANCE.NS, TCS.NS, INFY.NS (NSE stocks)

# --- Telegram Bot ---
# Get these from @BotFather on Telegram
# Bot Token: Ask @BotFather after creating your bot (looks like: 123456789:ABCDEFGHijklmnop...)
# Chat ID: Your personal Telegram user ID (send a message to your bot, then check getUpdates)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_EXTRA_CHAT_IDS=

# --- Scheduler ---
CHECK_INTERVAL_MINUTES=2
MARKET_HOURS_ONLY=true

# --- Alert Behavior ---
DEFAULT_COOLDOWN_MINUTES=30
MAX_ALERTS_PER_CYCLE=10

# --- Storage ---
DATABASE_PATH=data/alerts.db

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE_MB=10

# --- Zerodha API Credentials (Optional) ---
# Get from: https://developers.kite.trade
# Only needed if using Zerodha for trading
ZERODHA_ENABLED=false
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_ACCESS_TOKEN=your_zerodha_access_token_here
ZERODHA_USER_ID=your_zerodha_user_id_here

# --- Dhan API Credentials (Optional) ---
# Get from: https://dhan.co/developers
# Only needed if using Dhan for trading
DHAN_ENABLED=false
DHAN_API_KEY=your_dhan_api_key_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here
DHAN_USER_ID=your_dhan_user_id_here
